# WRAG Environment Configuration
# Copy this file to .env and modify as needed (start.sh does this automatically)

# --- WRAG Server ---
WRAG_HOST=0.0.0.0
WRAG_PORT=8000

# SAG API base URL (internal — WRAG communicates with SAG on this address)
SAG_API_URL=http://127.0.0.1:4173

# Markdown file storage directory (relative to WRAG/)
MD_STORAGE_DIR=md_storage

# File upload size limit in MB (blank = no limit)
# Set a value to enforce max upload size
# WRAG_MAX_UPLOAD_SIZE_MB=100

# --- PostgreSQL ---
DATABASE_URL=postgres://sag_lite:sag_lite_pass@localhost:5432/sag_lite
