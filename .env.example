# WRAG Environment Configuration
# Copy this file to .env and modify as needed

# --- WRAG Settings ---
WRAG_HOST=0.0.0.0
WRAG_PORT=8000

# SAG API base URL (internal, WRAG communicates with SAG on this address)
SAG_API_URL=http://127.0.0.1:4173

# Path to SAG project directory (relative to WRAG/)
SAG_DIR=../SAG

# Path to markitdown project directory (relative to WRAG/)
MARKITDOWN_DIR=../markitdown

# File upload size limit in MB (blank = no limit)
# Set a value to enforce max upload size
# WRAG_MAX_UPLOAD_SIZE_MB=100

# Markdown file storage directory (relative to WRAG/)
MD_STORAGE_DIR=md_storage

# --- PostgreSQL / SAG Settings ---
DATABASE_URL=postgres://sag_lite:sag_lite_pass@localhost:5432/sag_lite
DEFAULT_TENANT_ID=default
AUTH_MODE=none
LOG_LEVEL=info
NODE_ENV=development

# --- AI Provider Settings (passed through to SAG) ---
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.302ai.cn/v1

LLM_MODEL=qwen3.6-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.302ai.cn/v1
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2

RERANK_MODEL=qwen3-rerank
RERANK_INSTRUCT=Given a user question, rank SAG event candidates by relevance and usefulness for retrieval-augmented question answering.
DEFAULT_SEARCH_MODE=fast

# --- MCP Settings ---
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=4174
MCP_TOOL_TIMEOUT_MS=300000
